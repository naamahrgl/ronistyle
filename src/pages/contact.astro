---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'צרו קשר',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText tagline="Contact" title="בואו נדבר!" />

  <ContactUs
    id="contact"
    title="תכתבו לי עם כל שאלה!"
    subtitle="או התלבטות או התעניינות"
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'שם',
      },
      {
        type: 'email',
        name: 'email',
        label: 'אימייל',
      },
           {
        type: 'phone',
        name: 'phone',
        label: 'טלפון',
      },
    ]}
    textarea={{
      label: 'הודעה',
    }}
  disclaimer={{
      label:
        'על ידי שליחת טופס יצירת הקשר הזה, אתה מאשר ומסכים לאיסוף המידע האישי שלך.',
    }}
    description="צוות התמיכה שלנו בדרך כלל מגיב תוך 24 ימי עסקים."
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="אשמח לשמוע מכם"
    items={[

      {
        title: 'Phone',
        description: '+1 (234) 567-890',
        icon: 'tabler:phone',
      },
      {
        title: 'Email',
        description: 'contact@support.com',
        icon: 'tabler:mail',
      },
      {
        title: 'Location',
        description: '1234 Lorem Ipsum St, 12345, Miami, EEUU',
        icon: 'tabler:map-pin',
      },
    ]}
  />
</Layout>
