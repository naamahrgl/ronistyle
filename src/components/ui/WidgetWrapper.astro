---
import type { HTMLTag } from 'astro/types';
import type { Widget } from '~/types';
import { twMerge } from 'tailwind-merge';

export interface Props extends Widget {
  containerClass?: string;
  ['as']?: HTMLTag;
}

// We ignore isDark by forcing it to false
const { id, containerClass = '', bg, as = 'section' } = Astro.props;

const WrapperTag = as;
---

<WrapperTag class="relative not-prose scroll-mt-[72px]" {...id ? { id } : {}}>
  <div class="absolute inset-0 pointer-events-none -z-[1]" aria-hidden="true">
    <slot name="bg">
      {
        bg ? (
          <Fragment set:html={bg} />
        ) : (
          // Removed 'dark:bg-transparent'
          <div class="absolute inset-0" />
        )
      }
    </slot>
  </div>
  <div
    class:list={[
      twMerge(
        'relative mx-auto max-w-7xl px-4 md:px-6 py-12 md:py-16 lg:py-20 text-default intersect-once intersect-quarter intersect-no-queue motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade',
        containerClass
      ),
      // REMOVED: { dark: isDark } - This was the primary culprit injecting the class
    ]}
  >
    <slot />
  </div>
</WrapperTag>