---
import { Icon } from 'astro-icon/components';
import Button from '~/components/ui/Button.astro';
import Headline from '~/components/ui/Headline.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import type { Pricing as Props } from '~/types';

// 1. Import your image here
import bowtieImg from '~/assets/images/bowtie2.png'; 

const { title = '', subtitle = '', tagline = '', prices = [], id, isDark = false, classes = {}, bg = await Astro.slots.render('bg') } = Astro.props;
---

<WidgetWrapper id={id} isDark={isDark} containerClass={`max-w-7xl mx-auto ${classes?.container ?? ''}`} bg={bg}>
  <Headline title={title} subtitle={subtitle} tagline={tagline} />
  
  <div class="flex flex-wrap items-start justify-center gap-6">
    {prices && prices.map((price) => (
      <div class="w-full sm:w-[48%] lg:w-[30%] flex flex-col">
        
        <div class="flex flex-col w-full h-auto rounded-lg backdrop-blur border border-primary bg-[#f9e4e4] shadow px-6 py-8 relative transition-all duration-300">
          <div class="flex-grow">

          {/* Header Area */}
          <div class="relative">
            {/* 2. Bowtie Image Container */}
            {price.hasRibbon && (
              <div class="absolute -top-12 -right-12 z-[1] w-20 h-20 overflow-visible">
                <img 
                  src={bowtieImg.src} 
                  alt="Bowtie" 
                  class="w-full h-full object-contain rotate-45" 
                />
              </div>
            )}
            <h3 class="text-center text-xl font-semibold uppercase mb-4">{price.title}</h3>
          </div>

          {/* Toggle Area */}
            <input type="checkbox" id={`toggle-${price.title}`} class="peer hidden" />
            
            <div class="max-h-0 overflow-hidden peer-checked:max-h-[1000px] transition-all duration-500 ease-in-out">
              {price.subtitle && <p class="font-light text-muted mb-6">{price.subtitle}</p>}
              {price.items && (
                <ul class="space-y-3 text-right mb-6">
                  {price.items.map(({ description, icon, more_text }) => (
                    <li>
                      <div class="flex items-start space-x-3">
                        <div class="rounded-full bg-primary mt-1 shrink-0"><Icon name={icon || 'tabler:check'} class="w-4 h-4 p-0.5 text-white" /></div>
                        <span class="font-medium text-primary">{description}</span>
                      </div>
                      {more_text && <p class="text-sm text-muted mt-1 mr-7">{more_text}</p>}
                    </li>
                  ))}
                </ul>
              )}
            </div>

            <label for={`toggle-${price.title}`} class="flex justify-center mt-4 cursor-pointer text-muted hover:text-primary transition">
              <Icon name="tabler:chevron-down" class="w-6 h-6 transition-transform duration-300 peer-checked:rotate-180" />
            </label>
          </div>

          {price.callToAction && (
            <div class="mt-6 flex justify-center">
              <Button {...price.callToAction} />
            </div>
          )}
        </div>
      </div>
    ))}
  </div>
</WidgetWrapper>