---
import Image from '~/components/common/Image.astro';
import Button from '~/components/ui/Button.astro';
import type { Hero as Props } from '~/types';

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline,
  actions = await Astro.slots.render('actions'),
  image, 
  logo,    
  id,
} = Astro.props;
---

<section class="relative min-h-[60vh] flex items-center overflow-hidden" {...id ? { id } : {}}>
  


  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 w-full">
    {/* GRID: Content in first column, Spacer in second */}
    <div class="grid md:grid-cols-1 gap-8 items-center">
            {/* COLUMN 2: Empty spacer */}
      <div class="hidden md:block"></div>

      {/* COLUMN 1: Content (Logo, Text, Buttons) */}
      <div class="flex flex-col items-center text-center  text-[#451113]"> 
        {logo && (
          <div class="mb-8 w-full max-w-[560px] ">
            <Image class="w-full h-auto drop-shadow-2xl" {...logo} />
          </div>
        )}
        
        {tagline && <p class="text-[#451113] font-bold tracking-widest uppercase mb-4">{tagline}</p>}
        {subtitle && <div class="text-xl md:text-2xl mb-8 text-[#451113]" set:html={subtitle} />}
        
        {actions && (
          <div class="flex flex-col sm:flex-row gap-4">
            {Array.isArray(actions) ? (
              actions.map((action) => <Button {...(action || {})} />)
            ) : (
              <Fragment set:html={actions} />
            )}
          </div>
        )}
      </div>


    </div>
  </div>
    {/* BACKGROUND IMAGE - Full screen background */}
{image && (
  <div class="absolute top-0 right-0 w-screen h-full z-0 overflow-hidden">
    <Image
      class="w-full h-full object-cover object-center"
      widths={[400, 768, 1024, 2040]}
      sizes="100vw"
      loading="eager"
      {...image}
    />
    <div class="absolute inset-0 bg-white/60"></div>
  </div>
)}
</section>